{
  "video": {
    "width": 1280,
    "height": 720,
    "fps": 30,
    "camera_index": 1,
    "backend": "dshow",
    "buffer_size": 1
  },
  "ui": {
    "mirror_preview": true,
    "show_debug": true,
    "processing_interval_ms": 30,
    "theme": "graphite"
  },
  "tracking": {
    "eye_weight": 1.35,
    "head_weight_x": 0.95,
    "head_weight_y": 0.45,
    "vertical_gain": 1.5,
    "invert_x": true,
    "invert_y": true,
    "screen_margin": 0.08,
    "lost_face_hold_ms": 500,
    "sensitivity": 2.09,
    "face_detection_confidence": 0.5,
    "face_tracking_confidence": 0.5
  },
  "smoothing": {
    "min_cutoff": 1.0,
    "beta": 0.007,
    "d_cutoff": 1.0
  },
  "click": {
    "mode": "\u0631\u0645\u0634\u0629 (Blink)",
    "ear_threshold": 0.23,
    "min_close_ms": 150,
    "double_blink_window_ms": 300,
    "dwell_ms": 700,
    "dwell_radius_px": 20,
    "scroll_cooldown_ms": 70
  },
  "scrolling": {
    "pitch_deadzone_deg": 3.0,
    "pitch_gain": 1.0,
    "speed_cap": 10.0
  },
  "calibration": {
    "rows": 5,
    "cols": 5,
    "margin": 0.05,
    "edge_boost": 0.05,
    "edge_padding_px": 30,
    "target_radius_px": 18,
    "settle_frames": 12,
    "samples_per_point": 24,
    "stable_window": 8,
    "max_stability": 0.02,
    "min_tracking_quality": 0.4,
    "max_head_yaw": 22.0,
    "max_head_pitch": 18.0,
    "outlier_mad_scale": 2.5,
    "ridge": 0.0005,
    "validation_threshold_px": 140.0,
    "preferred_model": "tps_mapping",
    "order": "center-out",
    "samples_per_point_min": 40,
    "samples_per_point_max": 60,
    "max_head_variance": 5.0
  },
  "hotkeys": {
    "rest_mode": "<ctrl>+<alt>+e",
    "toggle_modes": "<ctrl>+<alt>+m",
    "start_calibration": "<ctrl>+<alt>+c"
  },
  "monitors": {
    "enable_multi_monitor": true,
    "auto_detect_dpi": true,
    "selected_monitor_index": 0
  },
  "logging": {
    "level": "INFO",
    "enable_performance_logging": true,
    "directory": "logs",
    "filename": "eyemouse.log"
  }
}